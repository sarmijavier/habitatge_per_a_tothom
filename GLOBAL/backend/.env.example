GOOGLE_API_KEY=pon_aqui_tu_clave_gemini
GROQ_API_KEY=pon_aqui_tu_clave_groq
MISTRAL_API_KEY=pon_aqui_tu_clave_mistral

GLOBAL_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GLOBAL_INCLUDE_CATEGORIES=leyes,derivados
GLOBAL_INCLUDE_COUNTRIES=espana,singapur,cuba,venezuela
GLOBAL_INDEX_DATASET_CARDS=false

# Ajustes utiles para free tier de Gemini al construir embeddings:
# GLOBAL_EMBEDDING_BATCH_SIZE=20
# GLOBAL_EMBEDDING_RETRY_SECONDS=65
# GLOBAL_MAX_DOCUMENTS=20
# GLOBAL_MAX_CHUNKS=120

# Si quieres probar sin claves reales:
# GLOBAL_DEMO_MODE=true
